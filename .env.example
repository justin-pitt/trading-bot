# ── NinjaTrader AT Interface ────────────────────────────────────────────────
NT_HOST=127.0.0.1
NT_PORT=36973
NT_ACCOUNT=Sim101          # Your NT8 account name (Sim101 for simulation)

# ── Account ─────────────────────────────────────────────────────────────────
ACCOUNT_VALUE=100000        # Starting account value in USD

# ── Symbols & Timing ────────────────────────────────────────────────────────
SYMBOLS=ES,NQ,CL            # Comma-separated futures symbols to trade
SCAN_INTERVAL=30            # Seconds between scans

# ── Live NT8 Bar Data ────────────────────────────────────────────────────────
LIVE_DATA_DIR=C:\NinjaTrader\LiveBars   # Must match Export Directory in LiveBarExporter
LIVE_INTERVAL=1D                         # Match bar type on your NT8 chart (1D, 5M, 15M, 60M)

# ── LangChain AI Layer (optional) ───────────────────────────────────────────
USE_LANGCHAIN=false         # Set to true to enable sentiment filtering
ANTHROPIC_API_KEY=          # Required if USE_LANGCHAIN=true
